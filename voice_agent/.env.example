# Vertex AI (required for Agent Engine deployment)
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Agent Engine staging bucket (deploy.py also accepts STAGING_BUCKET)
GOOGLE_CLOUD_STAGING_BUCKET=gs://your-project-adk-staging

# Live API native-audio model (Vertex)
VOICE_AGENT_MODEL=gemini-live-2.5-flash-native-audio

# Set after deploy (or use agent_engine/agent_resource_name.txt locally)
AGENT_ENGINE_RESOURCE_NAME=projects/PROJECT/locations/REGION/reasoningEngines/ID

# Mic clients — tune for loudspeaker / noisy rooms
MIC_ENERGY_THRESHOLD=400
MIC_ECHO_COOLDOWN_MS=500

# Auth: use `gcloud auth application-default login` (recommended).
# Do not commit service account key JSON files.
